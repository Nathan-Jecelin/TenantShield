{
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap/:id.xml",
      "destination": "/api/sitemap/:id"
    }
  ],
  "crons": [
    {
      "path": "/api/newsletter/send",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/address-watch/check",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/landlord-alerts/check",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/analytics/aggregate",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/reports/followup",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/refresh-sitemap?chunk=0",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/refresh-sitemap?chunk=1",
      "schedule": "2 3 * * *"
    },
    {
      "path": "/api/cron/refresh-sitemap?chunk=2",
      "schedule": "4 3 * * *"
    },
    {
      "path": "/api/cron/refresh-sitemap?chunk=3",
      "schedule": "6 3 * * *"
    },
    {
      "path": "/api/cron/refresh-sitemap?chunk=4",
      "schedule": "8 3 * * *"
    },
    {
      "path": "/api/cron/refresh-sitemap?chunk=5",
      "schedule": "10 3 * * *"
    }
  ]
}
