{
  "rewrites": [
    {
      "source": "/sitemap/:id.xml",
      "destination": "/api/sitemap/:id"
    }
  ],
  "crons": [
    {
      "path": "/api/newsletter/send",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/address-watch/check",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/landlord-alerts/check",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/analytics/aggregate",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/reports/followup",
      "schedule": "0 15 * * *"
    }
  ]
}
